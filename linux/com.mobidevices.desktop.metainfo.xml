<component type="desktop-application">
    <id>com.mobidevices.desktop</id>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>MIT</project_license>
    <name>MobiDevices</name>
    <summary>Official desktop client for MobiDevices.com</summary>
    <developer_name>MobiDevices</developer_name>
    <launchable type="desktop-id">com.mobidevices.desktop.desktop</launchable>
    <update_contact>md@mobidevices.com</update_contact>

    <description>
        <p>MobiDevices is the official Tauri-based desktop client for MobiDevices.com, bringing the publication into a dedicated native window instead of a browser tab.</p>
        <p>The app preserves the live website experience while adding desktop-native behavior around it.</p>
        <ul>
            <li>Opens external links in the default browser</li>
            <li>Provides localized native navigation actions</li>
            <li>Keeps the window title in sync with the current page</li>
            <li>Restores the previous desktop window size and position</li>
        </ul>
    </description>

