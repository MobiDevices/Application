# Maintainer: MobiDevices <md@mobidevices.com>
pkgname=mobidevices
pkgver=1.0.1
pkgrel=1
pkgdesc="Desktop app for MobiDevices.com"
arch=('x86_64')
url="https://mobidevices.com"
license=('WTFPL')
depends=('gtk3' 'webkit2gtk-4.1')
makedepends=('cargo' 'npm')
source=("$pkgname-$pkgver.tar.gz::https://github.com/MobiDevices/MobiDevices-app/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "$srcdir/MobiDevices-app-$pkgver"
    npm ci
}

build() {
    cd "$srcdir/MobiDevices-app-$pkgver"
    npm run build
}

package() {
    install -Dm644 "$srcdir/MobiDevices-app-$pkgver/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

    sh "$srcdir/MobiDevices-app-$pkgver/linux/install-assets.sh" \
        "$srcdir/MobiDevices-app-$pkgver/src-tauri/target/release/mobidevices-app" \
        "$pkgdir/usr/bin" \
        mobidevices \
        "$srcdir/MobiDevices-app-$pkgver/linux/mobidevices.desktop.in" \
        "$pkgdir/usr/share" \
        com.mobidevices.desktop.desktop \
        mobidevices \
        com.mobidevices.desktop \
        "$srcdir/MobiDevices-app-$pkgver/src-tauri/icons" \
        com.mobidevices.desktop \
        "$srcdir/MobiDevices-app-$pkgver/linux/com.mobidevices.desktop.metainfo.xml" \
        com.mobidevices.desktop.metainfo.xml
}
