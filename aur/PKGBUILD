# Maintainer: MobiDevices <md@mobidevices.com>
pkgname=mobidevices
pkgver=1.0.0
pkgrel=1
pkgdesc="Media about gadgets and technologies"
arch=('x86_64')
url="https://mobidevices.com"
license=('MIT')
depends=('webkit2gtk' 'gtk3')
makedepends=('rust' 'cargo' 'npm')
source=("$pkgname-$pkgver.tar.gz::https://github.com/MobiDevices/MobiDevices/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "$srcdir/MobiDevices-$pkgver/app"
    npm install
}

build() {
    cd "$srcdir/MobiDevices-$pkgver/app"
    npm run build
}

package() {
    sh "$srcdir/MobiDevices-$pkgver/app/scripts/install-linux-assets.sh" \
        "$srcdir/MobiDevices-$pkgver/app/src-tauri/target/release/mobidevices-app" \
        "$pkgdir/usr/bin" \
        mobidevices \
    "$srcdir/MobiDevices-$pkgver/app/linux/mobidevices.desktop.in" \
        "$pkgdir/usr/share" \
        mobidevices.desktop \
    mobidevices \
    mobidevices \
        "$srcdir/MobiDevices-$pkgver/app/src-tauri/icons" \
        mobidevices
}
