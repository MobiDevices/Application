{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "MobiDevices",
    "version": "1.0.0",
    "identifier": "com.mobidevices.desktop",
    "build": {
        "devUrl": "https://mobidevices.com"
    },
    "app": {
        "withGlobalTauri": false,
        "windows": [],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "targets": "all",
        "macOS": {
            "minimumSystemVersion": "10.13"
        },
        "windows": {
            "webviewInstallMode": {
                "type": "embedBootstrapper"
            },
            "nsis": {
                "installMode": "perMachine"
            }
        },
        "iOS": {
            "developmentTeam": ""
        }
    }
}
