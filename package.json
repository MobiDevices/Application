{
    "name": "mobidevices-app",
    "version": "1.0.0",
    "description": "Native desktop client for MobiDevices.com",
    "homepage": "https://mobidevices.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/MobiDevices/MobiDevices-app.git"
    },
    "bugs": {
        "url": "https://github.com/MobiDevices/MobiDevices-app/issues"
    },
    "type": "module",
    "scripts": {
        "tauri": "tauri",
        "dev": "tauri dev",
        "build": "tauri build --bundles app",
        "build:dmg": "bash scripts/clean-dmg-mounts.sh && tauri build --bundles dmg",
        "validate:linux-assets": "bash scripts/validate-linux-assets.sh src-tauri/target/release/mobidevices-app"
    },
    "devDependencies": {
        "@tauri-apps/cli": "2.10.0"
    },
    "dependencies": {
        "@tauri-apps/api": "2.10.1"
    }
}
