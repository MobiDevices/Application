{
    "name": "mobidevices-app",
    "version": "1.0.0",
    "description": "Native desktop client for MobiDevices.com",
    "homepage": "https://mobidevices.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/MobiDevices/MobiDevices-app.git"
    },
    "bugs": {
        "url": "https://github.com/MobiDevices/MobiDevices-app/issues"
    },
    "type": "module",
    "scripts": {
        "tauri": "tauri",
        "dev": "tauri dev",
        "build": "tauri build --bundles app",
        "build:dmg": "bash macos/clean-dmg-mounts.sh && tauri build --bundles dmg",
        "build:flatpak": "sh flatpak/build.sh",
        "prepare:flathub-submission": "sh flatpak/export-flathub-submission.sh",
        "generate:flatpak-sources": "bash flatpak/generate-cargo-sources.sh",
        "validate:linux-assets": "bash linux/validate-assets.sh"
    },
    "devDependencies": {
        "@tauri-apps/cli": "2.10.1"
    },
    "dependencies": {
        "@tauri-apps/api": "2.10.1"
    }
}
